{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git checkout feature/multi-court-phase5)",
      "Bash(git pull origin feature/multi-court-phase5)",
      "Bash(python -m py_compile calypso-bridge/bridge.py)",
      "Bash(py -3 -m py_compile calypso-bridge/bridge.py)",
      "Bash(git add:*)",
      "Bash(git commit -m ':*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(npm run:*)",
      "mcp__Claude_Preview__preview_start",
      "Bash(npx vite:*)",
      "Bash(git stash:*)",
      "Bash(git branch:*)",
      "Bash(git commit -m 'docs\\(step4\\): 第2弾B 事前確認レポートとC1データ収集結果を追加:*)",
      "Bash(git check-ignore:*)",
      "Bash(echo \"\\(終了コード: $?\\)\")",
      "Bash(gh --version)",
      "Bash(gh pr create --base main --head feature/step4-phase2b --title '第2弾B-α: DESIGN.md セマンティックカラー整理 + --danger 追加' --body ':*)",
      "Bash(gh pr create --title '第2弾B-β: セマンティックカラーの実コード展開' --body ':*)",
      "Bash(git commit:*)",
      "Bash(gh pr create --base main --head docs/pitfalls-phase2b-lessons --title 'docs\\(pitfalls\\): 第2弾B で得た運用知見4項目を known-pitfalls.md に追加' --body ':*)",
      "Bash(mkdir -p /tmp/css-check)",
      "Bash(cp -r dist/assets /tmp/css-check/dist-before)",
      "Bash(cp -r dist/assets /tmp/css-check/dist-after)",
      "Read(//tmp/css-check/**)",
      "Bash(gh pr create --title 'refactor: Semantic → Primitive var\\(\\) 参照化（DESIGN.md §2.11.4 解消）' --body ':*)",
      "Bash(git update-index *)",
      "Bash(git hash-object *)",
      "Bash(grep -E '\\\\.env\\($|\\\\.local|\\\\.production\\)')",
      "Bash(grep -rn '\\\\\\\\u[0-9a-fA-F]\\\\{4\\\\}' --include='*.js' --include='*.jsx' src/)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const d=JSON.parse(require('fs').readFileSync(0,'utf8'));const f=(d.tool_input||{}).file_path||'';if(/\\\\.(jsx?|tsx?)$/.test(f)){try{const r=require('child_process').execSync('grep -n console.log '+JSON.stringify(f),{encoding:'utf8'}).split('\\\\n').filter(l=>l&&!l.includes('// keep'));if(r.length){process.stderr.write('[Warning] console.log残存:\\\\n'+r.join('\\\\n')+'\\\\n')}}catch(e){}}\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const d=JSON.parse(require('fs').readFileSync(0,'utf8'));if(((d.tool_input||{}).command||'').includes('git push')){process.stderr.write('[Reminder] git push検出。build確認・console.logチェック・diff確認は済みましたか?\\\\n')}\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
