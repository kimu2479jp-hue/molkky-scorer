{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git checkout feature/multi-court-phase5)",
      "Bash(git pull origin feature/multi-court-phase5)",
      "Bash(python -m py_compile calypso-bridge/bridge.py)",
      "Bash(py -3 -m py_compile calypso-bridge/bridge.py)",
      "Bash(git add:*)",
      "Bash(git commit -m ':*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(npm run:*)",
      "mcp__Claude_Preview__preview_start",
      "Bash(npx vite:*)",
      "Bash(git stash:*)",
      "Bash(git branch:*)",
      "Bash(git commit -m 'docs\\(step4\\): 第2弾B 事前確認レポートとC1データ収集結果を追加:*)",
      "Bash(git check-ignore:*)",
      "Bash(echo \"\\(終了コード: $?\\)\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const d=JSON.parse(require('fs').readFileSync(0,'utf8'));const f=(d.tool_input||{}).file_path||'';if(/\\\\.(jsx?|tsx?)$/.test(f)){try{const r=require('child_process').execSync('grep -n console.log '+JSON.stringify(f),{encoding:'utf8'}).split('\\\\n').filter(l=>l&&!l.includes('// keep'));if(r.length){process.stderr.write('[Warning] console.log残存:\\\\n'+r.join('\\\\n')+'\\\\n')}}catch(e){}}\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const d=JSON.parse(require('fs').readFileSync(0,'utf8'));if(((d.tool_input||{}).command||'').includes('git push')){process.stderr.write('[Reminder] git push検出。build確認・console.logチェック・diff確認は済みましたか?\\\\n')}\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
